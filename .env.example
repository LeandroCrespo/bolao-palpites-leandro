# Copie este arquivo para .env e preencha seus valores

# Chave da API Anthropic — obtenha em console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# URL do banco PostgreSQL do bolão
# Encontre em: Streamlit Cloud > seu app > Settings > Secrets
# Procure pela variável DATABASE_URL
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# Seu ID numérico de usuário no banco do bolão
# Para descobrir: faça login no app, peça ao administrador ou consulte o banco
BOLAO_USER_ID=1
